<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Belegeinreichung — SP AR</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #fafafa;
    --surface: #ffffff;
    --surface2: #f4f4f5;
    --border: #e4e4e7;
    --text: #18181b;
    --muted: #71717a;
    --sp-red: #e30613;
    --sp-red-light: rgba(227,6,19,.08);
    --sp-red-border: rgba(227,6,19,.2);
    --green: #16a34a;
    --green-bg: rgba(22,163,74,.08);
    --radius: 10px;
    --shadow: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
    --shadow-lg: 0 10px 25px rgba(0,0,0,.08);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', -apple-system, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

  .header {
    background: var(--sp-red);
    color: white;
    padding: 28px 24px 24px;
    text-align: center;
  }
  .header .logo { font-size: 14px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; opacity: .85; margin-bottom: 6px; }
  .header h1 { font-size: 24px; font-weight: 700; }
  .header p { font-size: 14px; opacity: .8; margin-top: 4px; }

  .container { max-width: 560px; margin: -20px auto 40px; padding: 0 16px; position: relative; z-index: 1; }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    box-shadow: var(--shadow);
    margin-bottom: 16px;
  }
  .card h2 { font-size: 16px; font-weight: 700; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }

  label { display: block; margin-bottom: 14px; }
  label .lbl { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 5px; display: block; }
  label .lbl .req { color: var(--sp-red); }
  input[type="text"], input[type="number"], input[type="date"], textarea, select {
    width: 100%;
    padding: 10px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 14px;
    font-family: inherit;
    color: var(--text);
    background: var(--surface);
    transition: border-color .2s;
  }
  input:focus, textarea:focus, select:focus { outline: none; border-color: var(--sp-red); box-shadow: 0 0 0 3px var(--sp-red-light); }
  textarea { min-height: 80px; resize: vertical; }

  .row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media(max-width:480px) { .row { grid-template-columns: 1fr; } }

  .toggle { display: flex; align-items: center; gap: 10px; cursor: pointer; }
  .toggle input { display: none; }
  .toggle .track { width: 42px; height: 24px; background: var(--border); border-radius: 12px; position: relative; transition: background .2s; flex-shrink: 0; }
  .toggle .track::after { content: ''; position: absolute; top: 2px; left: 2px; width: 20px; height: 20px; background: white; border-radius: 50%; transition: transform .2s; box-shadow: 0 1px 3px rgba(0,0,0,.15); }
  .toggle input:checked + .track { background: var(--green); }
  .toggle input:checked + .track::after { transform: translateX(18px); }
  .toggle .text { font-size: 14px; font-weight: 500; }

  .file-drop {
    border: 2px dashed var(--border);
    border-radius: var(--radius);
    padding: 28px;
    text-align: center;
    cursor: pointer;
    transition: all .2s;
    position: relative;
    overflow: hidden;
  }
  .file-drop:hover, .file-drop.dragover { border-color: var(--sp-red); background: var(--sp-red-light); }
  .file-drop .icon { font-size: 32px; margin-bottom: 8px; }
  .file-drop .text { font-size: 13px; color: var(--muted); }
  .file-drop .text strong { color: var(--sp-red); }
  .file-drop input { position: absolute; inset: 0; opacity: 0; cursor: pointer; }
  .file-preview { display: flex; align-items: center; gap: 10px; padding: 10px; background: var(--surface2); border-radius: 8px; margin-top: 10px; }
  .file-preview .name { font-size: 13px; font-weight: 500; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .file-preview .size { font-size: 11px; color: var(--muted); }
  .file-preview .remove { background: none; border: none; color: var(--muted); cursor: pointer; font-size: 16px; padding: 4px; }

  .btn-submit {
    width: 100%;
    padding: 14px;
    background: var(--sp-red);
    color: white;
    border: none;
    border-radius: var(--radius);
    font-size: 15px;
    font-weight: 700;
    font-family: inherit;
    cursor: pointer;
    transition: all .2s;
    box-shadow: 0 2px 8px rgba(227,6,19,.25);
  }
  .btn-submit:hover { background: #c40511; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(227,6,19,.3); }
  .btn-submit:disabled { opacity: .5; cursor: not-allowed; transform: none; }

  .success {
    text-align: center;
    padding: 40px 20px;
  }
  .success .icon { font-size: 56px; margin-bottom: 16px; }
  .success h2 { font-size: 20px; margin-bottom: 8px; color: var(--green); }
  .success p { font-size: 14px; color: var(--muted); line-height: 1.6; }
  .success .btn-new {
    display: inline-block;
    margin-top: 20px;
    padding: 10px 24px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    cursor: pointer;
    text-decoration: none;
    font-family: inherit;
  }
  .success .btn-new:hover { background: var(--border); }

  .footer { text-align: center; padding: 24px; font-size: 12px; color: var(--muted); }

  .error-msg { background: rgba(227,6,19,.08); border: 1px solid rgba(227,6,19,.2); border-radius: 8px; padding: 10px 14px; font-size: 13px; color: var(--sp-red); margin-bottom: 14px; display: none; }

  .spinner { display: inline-block; width: 18px; height: 18px; border: 2px solid rgba(255,255,255,.3); border-top-color: white; border-radius: 50%; animation: spin .6s linear infinite; vertical-align: middle; margin-right: 6px; }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>
<body>

<div class="header">
  <div class="logo">SP Appenzell Ausserrhoden</div>
  <h1>📄 Belegeinreichung</h1>
  <p>Belege und Quittungen einreichen an den Kassier</p>
</div>

<div class="container">
  <!-- Form -->
  <div id="formView">
    <div class="card">
      <h2>📋 Beleg einreichen</h2>
      
      <div id="errorMsg" class="error-msg"></div>

      <label>
        <span class="lbl">Dein Name <span class="req">*</span></span>
        <input type="text" id="fName" placeholder="Vor- und Nachname" />
      </label>

      <label>
        <span class="lbl">Beleg-Titel <span class="req">*</span></span>
        <input type="text" id="fTitle" placeholder="z.B. Druckkosten Flyer, Saalmiete, Material" />
      </label>

      <div class="row">
        <label>
          <span class="lbl">Betrag (CHF) <span class="req">*</span></span>
          <input type="number" id="fAmount" placeholder="0.00" step="0.05" min="0" />
        </label>
        <label>
          <span class="lbl">Fälligkeitsdatum</span>
          <input type="date" id="fDueDate" />
        </label>
      </div>

      <label>
        <span class="lbl">Bereits bezahlt?</span>
        <label class="toggle">
          <input type="checkbox" id="fPaid" />
          <span class="track"></span>
          <span class="text" id="fPaidText">Nein, noch offen</span>
        </label>
      </label>

      <label>
        <span class="lbl">Kommentar</span>
        <textarea id="fComment" placeholder="Zusätzliche Informationen zum Beleg..."></textarea>
      </label>
    </div>

    <div class="card">
      <h2>📎 Dokument anhängen</h2>
      <div class="file-drop" id="fileDrop">
        <div class="icon">📄</div>
        <div class="text">Datei hier ablegen oder <strong>klicken zum Auswählen</strong></div>
        <div class="text" style="margin-top:4px;font-size:11px">PDF, JPG, PNG · Max. 5 MB</div>
        <input type="file" id="fFile" accept=".pdf,.jpg,.jpeg,.png,.heic,.webp" />
      </div>
      <div id="filePreview" style="display:none">
        <div class="file-preview">
          <span style="font-size:20px" id="fileIcon">📄</span>
          <span class="name" id="fileName"></span>
          <span class="size" id="fileSize"></span>
          <button class="remove" onclick="removeFile()">✕</button>
        </div>
      </div>
    </div>

    <button class="btn-submit" id="submitBtn" onclick="submitBeleg()">
      📤 Beleg einreichen
    </button>
  </div>

  <!-- Success -->
  <div id="successView" style="display:none">
    <div class="card">
      <div class="success">
        <div class="icon">✅</div>
        <h2>Beleg eingereicht!</h2>
        <p>Dein Beleg wurde erfolgreich übermittelt.<br>Der Kassier wird ihn prüfen und bearbeiten.</p>
        <button class="btn-new" onclick="resetForm()">📄 Weiteren Beleg einreichen</button>
      </div>
    </div>
  </div>
</div>

<div class="footer">
  SP Appenzell Ausserrhoden · Belegeinreichung · Kassier
</div>

<script>
let selectedFile = null;
let fileBase64 = null;

// Toggle text
document.getElementById('fPaid').addEventListener('change', function() {
  document.getElementById('fPaidText').textContent = this.checked ? 'Ja, bereits bezahlt' : 'Nein, noch offen';
});

// File handling
const fileDrop = document.getElementById('fileDrop');
const fileInput = document.getElementById('fFile');

fileDrop.addEventListener('dragover', (e) => { e.preventDefault(); fileDrop.classList.add('dragover'); });
fileDrop.addEventListener('dragleave', () => fileDrop.classList.remove('dragover'));
fileDrop.addEventListener('drop', (e) => {
  e.preventDefault();
  fileDrop.classList.remove('dragover');
  if (e.dataTransfer.files.length) handleFile(e.dataTransfer.files[0]);
});

fileInput.addEventListener('change', function() {
  if (this.files.length) handleFile(this.files[0]);
});

function handleFile(file) {
  const maxSize = 5 * 1024 * 1024;
  if (file.size > maxSize) {
    showError('Datei zu gross (max. 5 MB)');
    return;
  }
  const allowed = ['application/pdf', 'image/jpeg', 'image/png', 'image/webp', 'image/heic'];
  if (!allowed.includes(file.type) && !file.name.match(/\.(pdf|jpg|jpeg|png|webp|heic)$/i)) {
    showError('Nur PDF und Bilder erlaubt');
    return;
  }
  selectedFile = file;
  document.getElementById('fileName').textContent = file.name;
  document.getElementById('fileSize').textContent = (file.size / 1024).toFixed(0) + ' KB';
  document.getElementById('fileIcon').textContent = file.type.startsWith('image/') ? '🖼️' : '📄';
  document.getElementById('filePreview').style.display = 'block';
  fileDrop.style.display = 'none';
  hideError();

  // Convert to base64
  const reader = new FileReader();
  reader.onload = () => {
    fileBase64 = reader.result.split(',')[1]; // Remove data:... prefix
  };
  reader.readAsDataURL(file);
}

function removeFile() {
  selectedFile = null;
  fileBase64 = null;
  fileInput.value = '';
  document.getElementById('filePreview').style.display = 'none';
  fileDrop.style.display = 'block';
}

function showError(msg) {
  const el = document.getElementById('errorMsg');
  el.textContent = msg;
  el.style.display = 'block';
  el.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function hideError() {
  document.getElementById('errorMsg').style.display = 'none';
}

async function submitBeleg() {
  hideError();

  const name = document.getElementById('fName').value.trim();
  const title = document.getElementById('fTitle').value.trim();
  const amount = document.getElementById('fAmount').value;
  const dueDate = document.getElementById('fDueDate').value;
  const paid = document.getElementById('fPaid').checked;
  const comment = document.getElementById('fComment').value.trim();

  if (!name) { showError('Bitte gib deinen Namen ein'); return; }
  if (!title) { showError('Bitte gib einen Beleg-Titel ein'); return; }
  if (!amount || parseFloat(amount) <= 0) { showError('Bitte gib einen gültigen Betrag ein'); return; }

  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Wird gesendet...';

  try {
    const payload = {
      name,
      title,
      amount: parseFloat(amount),
      dueDate: dueDate || null,
      paid,
      comment,
      fileName: selectedFile?.name || null,
      fileType: selectedFile?.type || null,
      fileData: fileBase64 || null,
    };

    const r = await fetch('/.netlify/functions/beleg-submit', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
    });

    const data = await r.json();
    if (!r.ok) throw new Error(data.error || 'Fehler beim Senden');

    document.getElementById('formView').style.display = 'none';
    document.getElementById('successView').style.display = 'block';
    window.scrollTo({ top: 0, behavior: 'smooth' });
  } catch (err) {
    showError('Fehler: ' + err.message);
    btn.disabled = false;
    btn.innerHTML = '📤 Beleg einreichen';
  }
}

function resetForm() {
  document.getElementById('fName').value = '';
  document.getElementById('fTitle').value = '';
  document.getElementById('fAmount').value = '';
  document.getElementById('fDueDate').value = '';
  document.getElementById('fPaid').checked = false;
  document.getElementById('fPaidText').textContent = 'Nein, noch offen';
  document.getElementById('fComment').value = '';
  removeFile();
  document.getElementById('formView').style.display = 'block';
  document.getElementById('successView').style.display = 'none';
  document.getElementById('submitBtn').disabled = false;
  document.getElementById('submitBtn').innerHTML = '📤 Beleg einreichen';
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>
</body>
</html>
